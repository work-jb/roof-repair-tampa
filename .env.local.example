# Email Configuration (for nodemailer)
# Option A: Gmail (use an App Password, not your regular password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Where leads will be emailed
LEAD_RECIPIENT_EMAIL=you@yourdomain.com

# Option B: For local dev / testing without real email:
# Leave the above blank and leads will just be logged to console
